<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>CryptoClicker</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; font-family:'Segoe UI',sans-serif; user-select:none; }
        body { background:#0b0e14; color:#e0e0e0; min-height:100vh; display:flex; justify-content:center; align-items:center; padding:10px; }
        #app { max-width:420px; width:100%; background:#141a24; border-radius:24px; box-shadow:0 10px 30px rgba(0,0,0,0.7); overflow:hidden; position:relative; padding-bottom:56px; display:none; }
        .header { background:#1e2633; padding:10px 14px; display:flex; justify-content:space-between; align-items:center; border-bottom:2px solid #2a3342; }
        .header .title { font-weight:700; font-size:15px; background:linear-gradient(45deg,#f7b731,#f5a623); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
        .header .balance { display:flex; gap:10px; font-size:13px; }
        .header .balance span { display:flex; align-items:center; gap:3px; background:#0f151e; padding:2px 8px; border-radius:14px; border:1px solid #2a3342; }
        .fa-coins { color:#f7b731; }
        .fa-gem { color:#4fc3f7; }
        .content { padding:14px; min-height:280px; }
        .tab { display:none; animation:fadeIn 0.2s; }
        .tab.active { display:block; }
        @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
        .click-area { display:flex; flex-direction:column; align-items:center; }
        .big-balance { display:flex; gap:20px; font-size:20px; font-weight:700; margin-bottom:6px; background:#0f151e; padding:4px 14px; border-radius:30px; border:1px solid #2a3342; }
        .big-balance .coins { color:#f7b731; }
        .big-balance .diamonds { color:#4fc3f7; }
        .click-coin { width:110px; height:110px; border-radius:50%; background:radial-gradient(circle at 30% 30%,#f7d875,#e6a020); box-shadow:0 0 0 6px #2a3342,0 8px 20px rgba(0,0,0,0.6); display:flex; justify-content:center; align-items:center; font-size:48px; color:#fff; text-shadow:0 2px 8px rgba(0,0,0,0.5); cursor:pointer; transition:transform 0.1s,box-shadow 0.1s; margin-bottom:10px; position:relative; }
        .click-coin:active { transform:scale(0.92); box-shadow:0 0 0 10px #3e4a5e,0 4px 15px rgba(0,0,0,0.8); }
        .click-coin .fa-bolt { font-size:24px; opacity:0.2; position:absolute; bottom:6px; right:6px; }
        .energy-bar { width:100%; background:#1e2633; height:8px; border-radius:20px; margin:4px 0 8px; overflow:hidden; border:1px solid #2a3342; }
        .energy-fill { height:100%; background:linear-gradient(90deg,#4fc3f7,#29b6f6); border-radius:20px; transition:width 0.15s; }
        .energy-text { display:flex; justify-content:space-between; font-size:11px; color:#a0b0c0; }
        .stats { display:grid; grid-template-columns:1fr 1fr; gap:6px; width:100%; margin-top:8px; background:#1a222e; border-radius:12px; padding:8px; }
        .stats-item { text-align:center; background:#0f151e; padding:4px 0; border-radius:8px; }
        .stats-item .label { font-size:9px; color:#7a8a9e; }
        .stats-item .value { font-size:14px; font-weight:600; }
        .shop-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:6px; }
        .shop-card { background:#1a222e; border-radius:12px; padding:10px 6px; text-align:center; border:1px solid #2a3342; transition:0.2s; cursor:pointer; }
        .shop-card:hover { border-color:#f7b731; transform:translateY(-2px); }
        .shop-card .icon { font-size:22px; color:#f7b731; margin-bottom:2px; }
        .shop-card .name { font-weight:600; font-size:13px; }
        .shop-card .desc { font-size:10px; color:#8a9aaa; margin:2px 0 4px; }
        .shop-card .price { display:inline-block; background:#0f151e; padding:2px 10px; border-radius:16px; font-size:12px; border:1px solid #2a3342; }
        .shop-card .price i { margin-right:3px; }
        .shop-card .level { font-size:10px; color:#4fc3f7; margin-top:3px; }
        .shop-card.disabled { opacity:0.5; pointer-events:none; }
        .diamond-shop .shop-card .icon { color:#4fc3f7; }
        .diamond-shop .shop-card .price { border-color:#4fc3f7; }
        .leaderboard-list { margin-top:6px; }
        .leader-item { display:flex; justify-content:space-between; padding:6px 12px; background:#1a222e; border-radius:8px; margin-bottom:4px; border-left:3px solid #f7b731; }
        .leader-item .rank { font-weight:700; color:#f7b731; width:24px; font-size:13px; }
        .leader-item .name { flex:1; margin-left:8px; font-size:13px; }
        .leader-item .score { font-weight:600; font-size:13px; }
        .settings-group { background:#1a222e; border-radius:12px; padding:12px; margin-top:6px; }
        .settings-group label { display:block; font-size:12px; margin-bottom:3px; color:#aabaca; }
        .settings-group input { width:100%; padding:6px 10px; background:#0f151e; border:1px solid #2a3342; border-radius:8px; color:#e0e0e0; font-size:14px; outline:none; }
        .settings-group input:focus { border-color:#f7b731; }
        .settings-group .btn { margin-top:8px; background:#f7b731; color:#0b0e14; border:none; padding:8px; border-radius:20px; font-weight:700; font-size:14px; width:100%; cursor:pointer; transition:0.2s; }
        .settings-group .btn:hover { background:#f5a623; }
        .settings-group .btn-danger { background:#e74c3c; color:white; }
        .settings-group .btn-danger:hover { background:#c0392b; }
        #adminPanel { display:none; margin-top:10px; border-top:2px solid #2a3342; padding-top:10px; }
        #adminPanel.show { display:block; }
        .admin-grid { display:grid; grid-template-columns:1fr 1fr; gap:6px; }
        .admin-grid .admin-item { background:#0f151e; padding:6px; border-radius:8px; text-align:center; }
        .admin-grid .admin-item label { font-size:10px; color:#8a9aaa; }
        .admin-grid .admin-item input { width:100%; padding:3px; background:#1a222e; border:1px solid #2a3342; border-radius:4px; color:#e0e0e0; margin-top:3px; text-align:center; font-size:13px; }
        .admin-grid .admin-item .btn-small { margin-top:3px; background:#4fc3f7; border:none; padding:2px 8px; border-radius:12px; font-weight:600; color:#0b0e14; cursor:pointer; font-size:11px; }
        .bottom-nav { position:absolute; bottom:0; left:0; right:0; background:#1a222e; display:flex; justify-content:space-around; padding:4px 0 8px; border-top:2px solid #2a3342; }
        .nav-item { display:flex; flex-direction:column; align-items:center; font-size:10px; color:#7a8a9e; cursor:pointer; padding:2px 6px; border-radius:12px; transition:0.2s; background:transparent; border:none; gap:1px; }
        .nav-item i { font-size:18px; }
        .nav-item.active { color:#f7b731; background:#0f151e; }
        .nav-item.active i { color:#f7b731; }
        .float-text { position:fixed; pointer-events:none; font-size:22px; font-weight:700; color:#f7b731; text-shadow:0 0 20px rgba(247,183,49,0.5); animation:floatUp 0.7s ease-out forwards; z-index:100; }
        @keyframes floatUp { 0%{opacity:1;transform:translateY(0) scale(1)} 100%{opacity:0;transform:translateY(-80px) scale(1.3)} }
        @keyframes shake { 0%{transform:translateX(0)} 25%{transform:translateX(-6px)} 50%{transform:translateX(6px)} 75%{transform:translateX(-3px)} 100%{transform:translateX(0)} }
        .chest-btn { background:#f7b731; border:none; padding:10px; border-radius:24px; font-weight:700; font-size:16px; width:100%; cursor:pointer; color:#0b0e14; margin-top:8px; transition:0.2s; }
        .chest-btn:hover { background:#f5a623; transform:scale(1.02); }
        .chest-btn:disabled { opacity:0.5; cursor:not-allowed; transform:none; }
        .brand-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:6px; }
        .brand-card { background:#1a222e; border-radius:12px; padding:10px 6px; text-align:center; border:1px solid #2a3342; cursor:pointer; transition:0.2s; }
        .brand-card:hover { border-color:#4fc3f7; transform:translateY(-2px); }
        .brand-card .icon { font-size:28px; margin-bottom:2px; }
        .brand-card .name { font-weight:600; font-size:13px; }
        .brand-card .level { font-size:10px; color:#4fc3f7; margin:2px 0; }
        .brand-card .income { font-size:11px; color:#aabaca; }
        .brand-card .price { font-size:12px; color:#f7b731; }
        .brand-card.disabled { opacity:0.5; pointer-events:none; }

        .auth-screen { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:400px; padding:20px; }
        .auth-screen h2 { color:#f7b731; margin-bottom:20px; font-size:24px; }
        .auth-screen input { width:100%; padding:12px; background:#0f151e; border:1px solid #2a3342; border-radius:12px; color:#e0e0e0; font-size:16px; margin-bottom:12px; outline:none; }
        .auth-screen input:focus { border-color:#f7b731; }
        .auth-screen .btn { width:100%; padding:12px; border:none; border-radius:12px; font-weight:700; font-size:16px; cursor:pointer; transition:0.2s; }
        .auth-screen .btn-primary { background:#f7b731; color:#0b0e14; }
        .auth-screen .btn-primary:hover { background:#f5a623; }
        .auth-screen .btn-secondary { background:#2a3342; color:#e0e0e0; margin-top:8px; }
        .auth-screen .btn-secondary:hover { background:#3e4a5e; }
        .auth-screen .error { color:#e74c3c; font-size:14px; margin-bottom:10px; min-height:20px; }
        .auth-screen .switch-text { margin-top:12px; font-size:14px; color:#8a9aaa; }
        .auth-screen .switch-text span { color:#4fc3f7; cursor:pointer; }
        .auth-screen .switch-text span:hover { text-decoration:underline; }
        @media (max-width:420px){ .header .balance span{font-size:11px;padding:2px 6px;} .big-balance{font-size:17px;gap:14px;} .click-coin{width:90px;height:90px;font-size:38px;} .shop-grid{grid-template-columns:1fr 1fr;} .brand-grid{grid-template-columns:1fr 1fr;} }
    </style>
</head>
<body>

<!-- ЭКРАН ВХОДА / РЕГИСТРАЦИИ -->
<div id="authScreen" class="auth-screen">
    <h2>🔐 CryptoClicker</h2>
    <div class="error" id="authError"></div>
    <input type="text" id="authNick" placeholder="Никнейм">
    <input type="password" id="authPass" placeholder="Пароль">
    <button class="btn btn-primary" id="authLoginBtn">Войти</button>
    <button class="btn btn-secondary" id="authRegisterBtn">Зарегистрироваться</button>
    <div class="switch-text" id="authSwitch">
        Нет аккаунта? <span id="authSwitchLink">Зарегистрироваться</span>
    </div>
</div>

<!-- ОСНОВНОЕ ПРИЛОЖЕНИЕ -->
<div id="app">
    <div class="header">
        <div class="title"><i class="fas fa-bolt" style="color:#f7b731;margin-right:4px;"></i>CryptoClicker</div>
        <div class="balance">
            <span><i class="fas fa-coins"></i> <span id="headerCoins">0</span></span>
            <span><i class="fas fa-gem"></i> <span id="headerDiamonds">0</span></span>
            <span style="font-size:10px; background:transparent; border:none; padding:0;">👤 <span id="headerNick">Игрок</span></span>
        </div>
    </div>
    <div class="content">
        <!-- Главная -->
        <div id="tabMain" class="tab active">
            <div class="click-area">
                <div class="big-balance">
                    <span class="coins"><i class="fas fa-coins"></i> <span id="mainCoins">0</span></span>
                    <span class="diamonds"><i class="fas fa-gem"></i> <span id="mainDiamonds">0</span></span>
                </div>
                <div class="click-coin" id="clickCoin"><i class="fas fa-coins"></i><i class="fas fa-bolt"></i></div>
                <div class="energy-bar"><div class="energy-fill" id="energyFill" style="width:100%"></div></div>
                <div class="energy-text"><span>⚡ Энергия</span><span id="energyLabel">100 / 100</span></div>
                <div class="stats">
                    <div class="stats-item"><div class="label">Кликов</div><div class="value" id="statClicks">0</div></div>
                    <div class="stats-item"><div class="label">Доход за клик</div><div class="value" id="statClickPower">1</div></div>
                    <div class="stats-item"><div class="label">Макс. энергия</div><div class="value" id="statMaxEnergy">100</div></div>
                    <div class="stats-item"><div class="label">Пассивный доход</div><div class="value" id="statPassive">0/сек</div></div>
                </div>
            </div>
        </div>
        <!-- Магазин (монеты) -->
        <div id="tabShop" class="tab"><h3 style="margin-bottom:4px;font-size:15px;"><i class="fas fa-store"></i> Магазин</h3><div class="shop-grid" id="shopGrid"></div></div>
        <!-- Алмазный магазин -->
        <div id="tabDiamond" class="tab"><h3 style="margin-bottom:4px;font-size:15px;"><i class="fas fa-gem"></i> Алмазные улучшения</h3><div class="shop-grid diamond-shop" id="diamondShop"></div></div>
        <!-- Бизнес (филиалы-бренды) -->
        <div id="tabBusiness" class="tab">
            <h3 style="margin-bottom:4px;font-size:15px;"><i class="fas fa-building"></i> Филиалы</h3>
            <div class="brand-grid" id="brandGrid"></div>
        </div>
        <!-- Сундуки -->
        <div id="tabChest" class="tab">
            <h3 style="margin-bottom:4px;font-size:15px;"><i class="fas fa-box"></i> Сундуки</h3>
            <div style="background:#1a222e; border-radius:12px; padding:12px; margin-top:6px; text-align:center;">
                <p style="font-size:13px; color:#aabaca;">Открой сундук за 5 💎 и получи от 1000 до 10000 монет!</p>
                <button class="chest-btn" id="openChestBtn">🎁 Открыть (5 💎)</button>
                <div id="chestResult" style="margin-top:8px; font-size:17px; font-weight:700; color:#f7b731;"></div>
            </div>
        </div>
        <!-- Лидеры -->
        <div id="tabLeaders" class="tab"><h3 style="margin-bottom:4px;font-size:15px;"><i class="fas fa-trophy"></i> Таблица лидеров</h3><div class="leaderboard-list" id="leaderList"></div></div>
        <!-- Настройки -->
        <div id="tabSettings" class="tab">
            <h3 style="margin-bottom:4px;font-size:15px;"><i class="fas fa-cog"></i> Настройки</h3>
            <div class="settings-group">
                <label>Ваш ник: <strong id="settingsNick">Игрок</strong></label>
                <button class="btn btn-danger" id="logoutBtn">Выйти из аккаунта</button>
            </div>
            <div class="settings-group">
                <label>Админ-доступ</label>
                <input type="password" id="adminCodeInput" placeholder="Введите код" maxlength="4">
                <button class="btn btn-danger" id="adminUnlockBtn">Войти</button>
            </div>
            <div id="adminPanel">
                <h4 style="color:#f7b731;font-size:13px;"><i class="fas fa-user-shield"></i> Админ-панель</h4>
                <div class="admin-grid">
                    <div class="admin-item"><label>Ник игрока</label><input type="text" id="adminNick" placeholder="Ник"></div>
                    <div class="admin-item" style="grid-column:span 2;"><label>Монеты</label><div style="display:flex; gap:3px;"><input type="number" id="adminCoins" value="0"><button class="btn-small" id="adminSetCoins">Уст.</button><button class="btn-small" id="adminAddCoinsBtn">+</button><button class="btn-small" id="adminSubCoinsBtn">-</button></div></div>
                    <div class="admin-item" style="grid-column:span 2;"><label>Алмазы</label><div style="display:flex; gap:3px;"><input type="number" id="adminDiamonds" value="0"><button class="btn-small" id="adminSetDiamonds">Уст.</button><button class="btn-small" id="adminAddDiamondsBtn">+</button><button class="btn-small" id="adminSubDiamondsBtn">-</button></div></div>
                    <div class="admin-item"><label>Клик-пауэр</label><input type="number" id="adminClickPower" value="1"><button class="btn-small" data-target="clickPower">Уст.</button></div>
                    <div class="admin-item"><label>Макс. энергия</label><input type="number" id="adminMaxEnergy" value="100"><button class="btn-small" data-target="maxEnergy">Уст.</button></div>
                </div>
                <button class="btn btn-danger" id="adminResetBtn" style="margin-top:6px;font-size:13px;padding:6px;">Сбросить свой прогресс</button>
            </div>
        </div>
    </div>
    <div class="bottom-nav">
        <button class="nav-item active" data-tab="tabMain"><i class="fas fa-home"></i> Главная</button>
        <button class="nav-item" data-tab="tabShop"><i class="fas fa-store"></i> Магазин</button>
        <button class="nav-item" data-tab="tabDiamond"><i class="fas fa-gem"></i> Алмазы</button>
        <button class="nav-item" data-tab="tabBusiness"><i class="fas fa-building"></i> Бизнес</button>
        <button class="nav-item" data-tab="tabChest"><i class="fas fa-box"></i> Сундук</button>
        <button class="nav-item" data-tab="tabLeaders"><i class="fas fa-trophy"></i> Лидеры</button>
        <button class="nav-item" data-tab="tabSettings"><i class="fas fa-cog"></i> Настройки</button>
    </div>
</div>

<script>
// ================================================================
//  СИСТЕМА ПОЛЬЗОВАТЕЛЕЙ (хранилище в localStorage)
// ================================================================
const DB_KEY = 'clicker_users';

function loadUsers() {
    try {
        const data = localStorage.getItem(DB_KEY);
        if (data) return JSON.parse(data);
    } catch(e) {}
    return {};
}

function saveUsers(users) {
    localStorage.setItem(DB_KEY, JSON.stringify(users));
}

let currentUser = null;
let game = null;

// ================================================================
//  ЭКРАН ВХОДА / РЕГИСТРАЦИИ
